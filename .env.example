# ========================
# AI Game Platform - Environment Variables
# ========================

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=aigame
MYSQL_PASSWORD=aigame_password
MYSQL_DATABASE=aigame_platform
# SQLAlchemy connection URL (auto-generated from above)
DATABASE_URL=mysql+pymysql://aigame:aigame_password@localhost:3306/aigame_platform

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=games
MINIO_USE_SSL=false
# Public URL for frontend access (same as endpoint in dev)
MINIO_PUBLIC_URL=http://localhost:9000

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- MiniMax LLM API ---
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_API_URL=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_MODEL=MiniMax-Text-01

# --- App ---
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
